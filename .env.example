# Supabase — create a project (India region) at https://supabase.com, then:
#   1. copy this file to .env.local
#   2. fill these from Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Bypasses RLS — keep out of the client bundle and out of git.
SUPABASE_SERVICE_ROLE_KEY=

# Resume parsing — provider-agnostic (OpenAI-compatible wire format). Parsing only
# pre-fills; candidates confirm employers by hand, so this is OPTIONAL. Leave ALL of
# these blank to run with zero keys/cost (onboarding uses manual employer entry).
#
# Pick ONE cheap/free provider, e.g.:
#   Groq (free tier):   PARSE_LLM_BASE_URL=https://api.groq.com/openai/v1
#                       PARSE_LLM_MODEL=llama-3.3-70b-versatile
#   Gemini Flash:       PARSE_LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
#                       PARSE_LLM_MODEL=gemini-2.0-flash
#   Local Ollama ($0):  PARSE_LLM_BASE_URL=http://localhost:11434/v1
#                       PARSE_LLM_MODEL=qwen2.5   (leave PARSE_LLM_API_KEY blank)
PARSE_LLM_BASE_URL=
PARSE_LLM_MODEL=
PARSE_LLM_API_KEY=

# Optional fallback: Claude (used only if PARSE_LLM_BASE_URL is unset). Costs more.
ANTHROPIC_API_KEY=

# Transactional email (reveal intros, notifications) — added in Phase 4
RESEND_API_KEY=
OPENBENCH_FROM_EMAIL="OpenBench <hello@openbench.in>"

# Cron auth — generate a long random string; Vercel Cron sends it as a Bearer token
CRON_SECRET=

# Optional: override the resume-parse model (defaults to claude-sonnet-4-6)
OPENBENCH_PARSE_MODEL=
