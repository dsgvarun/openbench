# Supabase — create a project (India region) at https://supabase.com, then:
#   1. copy this file to .env.local
#   2. fill these from Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Bypasses RLS — keep out of the client bundle and out of git.
SUPABASE_SERVICE_ROLE_KEY=

# LLM pipeline (resume parsing, note screening) — added in Phase 2
ANTHROPIC_API_KEY=

# Transactional email (reveal intros, notifications) — added in Phase 4
RESEND_API_KEY=
